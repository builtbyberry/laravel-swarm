{
    "name": "builtbyberry/laravel-swarm",
    "description": "Multi-agent swarm orchestration for Laravel, built on Laravel AI.",
    "keywords": ["laravel", "ai", "agents", "swarm", "orchestration"],
    "homepage": "https://github.com/builtbyberry/laravel-swarm",
    "support": {
        "issues": "https://github.com/builtbyberry/laravel-swarm/issues",
        "source": "https://github.com/builtbyberry/laravel-swarm"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Berry",
            "email": "daniel@jstreetdigital.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/bus": "^13.0",
        "illuminate/cache": "^13.0",
        "illuminate/concurrency": "^13.0",
        "illuminate/console": "^13.0",
        "illuminate/container": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/events": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/queue": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/view": "^13.0",
        "laravel/ai": "^0.6"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "laravel/pulse": "^1.7",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "suggest": {
        "laravel/pulse": "Optional Pulse cards and recorders for swarm observability."
    },
    "autoload": {
        "psr-4": {
            "BuiltByBerry\\LaravelSwarm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BuiltByBerry\\LaravelSwarm\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "laravel": {
            "providers": [
                "BuiltByBerry\\LaravelSwarm\\SwarmServiceProvider"
            ],
            "aliases": {
                "Swarm": "BuiltByBerry\\LaravelSwarm\\Facades\\Swarm",
                "SwarmHistory": "BuiltByBerry\\LaravelSwarm\\Facades\\SwarmHistory"
            }
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G --no-progress",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "test": "vendor/bin/pest tests/Feature tests/Unit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
